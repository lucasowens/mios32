{
  "version": 4,
  "configurations": [
    {
      "name": "SEQ v4 (STM32F4)",
      "compilerPath": "/opt/homebrew/bin/arm-none-eabi-gcc",
      "compilerArgs": [
        "-mcpu=cortex-m4",
        "-mthumb",
        "-mlittle-endian"
      ],
      "cStandard": "c11",
      "cppStandard": "c++17",
      "intelliSenseMode": "linux-gcc-arm",
      "includePath": [
        "${workspaceFolder}/include/mios32",
        "${workspaceFolder}/programming_models/traditional",
        "${workspaceFolder}/FreeRTOS/Source/include",
        "${workspaceFolder}/FreeRTOS/Source/portable/GCC/ARM_CM3",
        "${workspaceFolder}/FreeRTOS/Source/portable/MemMang",
        "${workspaceFolder}/mios32/STM32F4xx",
        "${workspaceFolder}/drivers/STM32F4xx/v1.1.0/STM32F4xx_StdPeriph_Driver/inc",
        "${workspaceFolder}/drivers/STM32F4xx/v1.1.0/STM32_USB_Device_Library/Core/inc",
        "${workspaceFolder}/drivers/STM32F4xx/v1.1.0/STM32_USB_HOST_Library/Core/inc",
        "${workspaceFolder}/drivers/STM32F4xx/v1.1.0/STM32_USB_OTG_Driver/inc",
        "${workspaceFolder}/drivers/STM32F4xx/v1.1.0/CMSIS/Include",
        "${workspaceFolder}/drivers/STM32F4xx/v1.1.0/CMSIS/ST/STM32F4xx/Include",
        "${workspaceFolder}/modules/app_lcd/universal",
        "${workspaceFolder}/modules/blm",
        "${workspaceFolder}/modules/blm_scalar_master",
        "${workspaceFolder}/modules/aout",
        "${workspaceFolder}/modules/sequencer",
        "${workspaceFolder}/modules/notestack",
        "${workspaceFolder}/modules/midifile",
        "${workspaceFolder}/modules/fatfs",
        "${workspaceFolder}/modules/file",
        "${workspaceFolder}/modules/random",
        "${workspaceFolder}/modules/freertos_utils",
        "${workspaceFolder}/modules/uip",
        "${workspaceFolder}/modules/uip_task_standard",
        "${workspaceFolder}/apps/sequencers/midibox_seq_v4/core",
        "${workspaceFolder}/apps/sequencers/midibox_seq_v4/mios32"
      ],
      "defines": [
        "STM32F4XX",
        "USE_STDPERIPH_DRIVER",
        "USB_SUPPORT_USER_STRING_DESC",
        "MIOS32_FAMILY_STM32F4xx",
        "MIOS32_FAMILY_STR=\"STM32F4xx\"",
        "MIOS32_BOARD_MBHP_CORE_STM32F4",
        "MIOS32_BOARD_STR=\"MBHP_CORE_STM32F4\"",
        "MIOS32_PROCESSOR_STM32F407VG",
        "MIOS32_PROCESSOR_STR=\"STM32F407VG\"",
        "MIOS32_LCD_universal",
        "GCC_ARMCM3"
      ]
    },
    {
      "name": "app_skeleton (STM32F4)",
      "compilerPath": "/opt/homebrew/bin/arm-none-eabi-gcc",
      "compilerArgs": [
        "-mcpu=cortex-m4",
        "-mthumb",
        "-mlittle-endian"
      ],
      "cStandard": "c11",
      "intelliSenseMode": "linux-gcc-arm",
      "includePath": [
        "${workspaceFolder}/include/mios32",
        "${workspaceFolder}/programming_models/traditional",
        "${workspaceFolder}/FreeRTOS/Source/include",
        "${workspaceFolder}/FreeRTOS/Source/portable/GCC/ARM_CM3",
        "${workspaceFolder}/FreeRTOS/Source/portable/MemMang",
        "${workspaceFolder}/mios32/STM32F4xx",
        "${workspaceFolder}/drivers/STM32F4xx/v1.1.0/STM32F4xx_StdPeriph_Driver/inc",
        "${workspaceFolder}/drivers/STM32F4xx/v1.1.0/CMSIS/Include",
        "${workspaceFolder}/drivers/STM32F4xx/v1.1.0/CMSIS/ST/STM32F4xx/Include",
        "${workspaceFolder}/modules/app_lcd/universal",
        "${workspaceFolder}/apps/templates/app_skeleton"
      ],
      "defines": [
        "STM32F4XX",
        "USE_STDPERIPH_DRIVER",
        "USB_SUPPORT_USER_STRING_DESC",
        "MIOS32_FAMILY_STM32F4xx",
        "MIOS32_FAMILY_STR=\"STM32F4xx\"",
        "MIOS32_BOARD_MBHP_CORE_STM32F4",
        "MIOS32_BOARD_STR=\"MBHP_CORE_STM32F4\"",
        "MIOS32_PROCESSOR_STM32F407VG",
        "MIOS32_LCD_universal",
        "GCC_ARMCM3"
      ]
    }
  ]
}
